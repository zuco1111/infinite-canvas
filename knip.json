{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/app/feature-registry/index.ts",
    "src/design-lab/main.tsx",
    "src/design-lab/preview-main.tsx",
    "src/features/canvas/index.ts",
    "src/shared/ai/ai-provider-port.ts",
    "src/shared/commands/command-contract.ts",
    "src/shared/platform/index.ts",
    "src/shared/storage/repository-ports.ts",
    "src/shared/tokens/app.ts",
    "src/shared/tokens/canvas.ts",
    "electron/main/index.ts",
    "electron/preload/index.ts",
    "electron/agent/index.ts",
    "electron-builder.config.cjs"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "electron/**/*.ts",
    "tests/**/*.ts",
    "scripts/**/*.cjs",
    "*.config.{cjs,js,ts}"
  ],
  "ignoreDependencies": ["@openai/codex"],
  "exclude": ["exports", "types"]
}
