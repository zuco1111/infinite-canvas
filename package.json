{
  "name": "infinite-canvas-refactor",
  "version": "0.1.0",
  "private": true,
  "description": "React, Vite, and Electron skeleton for the Infinite Canvas refactor.",
  "type": "module",
  "main": "dist-electron/main/index.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:web": "vite --host 127.0.0.1",
    "dev:desktop": "npm-run-all --parallel dev:web dev:desktop:electron",
    "dev:desktop:electron": "wait-on tcp:5173 && npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron dist-electron/main/index.cjs",
    "build": "npm-run-all typecheck build:renderer build:electron",
    "build:renderer": "vite build",
    "build:electron": "npm-run-all build:electron:main build:electron:preload build:electron:agent",
    "build:electron:main": "esbuild electron/main/index.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist-electron/main/index.cjs",
    "build:electron:preload": "esbuild electron/preload/index.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist-electron/preload/index.cjs",
    "build:electron:agent": "esbuild electron/agent/index.ts --bundle --platform=node --format=esm --packages=bundle --outfile=dist-electron/agent/index.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p electron/tsconfig.json && tsc -p electron/agent/tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write \"*.{cjs,js,json,ts,html}\" \"{src,electron,tests}/**/*.{css,ts,tsx,json}\"",
    "format:check": "prettier --check \"*.{cjs,js,json,ts,html}\" \"{src,electron,tests}/**/*.{css,ts,tsx,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "npm-run-all format:check lint typecheck test",
    "knip": "knip",
    "clean": "rimraf dist dist-electron coverage playwright-report test-results"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex": "^0.142.5",
    "@tanstack/react-query": "^5.83.0",
    "@types/express": "^5.0.6",
    "@types/file-saver": "^2.0.7",
    "antd": "^5.20.0",
    "axios": "^1.18.1",
    "clsx": "^2.1.1",
    "copy-to-clipboard": "^4.0.2",
    "express": "^5.2.1",
    "fflate": "^0.8.3",
    "file-saver": "^2.0.5",
    "localforage": "^1.10.0",
    "lucide-react": "^0.468.0",
    "motion": "^12.42.2",
    "nanoid": "^5.1.16",
    "radix-ui": "^1.6.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.25.76",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "electron": "^43.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "knip": "^5.40.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^8.1.2",
    "vitest": "^4.1.9",
    "wait-on": "^8.0.1"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
